{
  "compilerOptions": {
    "target": "ESNext",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "rootDir": "../..",
    "paths": {
      "@/*": ["./src/*"],
      "@synccode/types/*": ["../../packages/types/*"]
    },
    "lib": ["ESNext"],
  },
  "include": ["src/**/*", "jest.setup.ts", "jest.config.ts"]
}
